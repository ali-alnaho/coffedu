// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// state enum
enum EnrollmentStatus {
  ACTIVE
  REPEATED
  GRADUATED
  WITHDRAWN
}

// Role enum
enum Role {
  USER
  STUDENT
  MANAGER
  TEACHER
  ADMIN
}

// User table 
model User {
  // [Name]  [Type]  [Attributes]
  // Primary key
  id String @id @default(cuid())

  // Data fields 
  firstName  String?
  familyName String?
  email      String? @unique
  userName   String  @unique
  password   String

  //Dates 
  createdAt DateTime @default(now())

  // Relations 
  role Role @default(USER)

  // FK + @unique ==> relation one to one with student model
  //  @unique ==> only one row can have that FK value
  studentId String?  @unique
  student   Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  // relation one to one with Teacher model
  teacherId String?  @unique
  teacher   Teacher? @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

// teacher Table 
model Teacher {
  id String @id @default(cuid())

  firstName        String
  fatherName       String
  grandName        String
  theFourthName    String?
  familyName       String?
  motherFirstName  String
  motherFatherName String
  dateOfBirth      DateTime @db.Date

  // more information 
  mobileNumber                String?
  academicQualification       String?
  specialization              String?
  nameOfUniversity            String?
  yearOfGraduation            DateTime? @db.Date
  dateOfFirstCommencement     DateTime? @db.Date
  ministerialAppointmentOrder DateTime? @db.Date

  // Dates
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations 
  user User?
}

// student table
model Student {
  // Primary key
  id String @id @default(cuid())

  // Data fields
  firstName        String
  fatherName       String
  grandName        String
  theFourthName    String?
  familyName       String?
  motherFirstName  String
  motherFatherName String
  dateOfBirth      DateTime @db.Date

  // Dates
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  studentEnrollments StudentEnrollments[]
  users              User?
}

// acadimic_years model 
model AcademicYears {
  // Primary key
  id        String   @id @default(cuid())
  year      String   @unique // e.g. "2024-2025" 
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)

  // Date 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  studentEnrollments StudentEnrollments[]
}

model GradeLevels {
  // Primary Key
  id    String @id @default(cuid())
  level Int    @unique // e.g. level = 1
  name  String // e.g. name = "First Grade"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  studentEnrollments StudentEnrollments[]
}

model StudentEnrollments {
  id         String @id @default(cuid())
  // relation field 
  studentId  String
  gradeId    String
  academicId String

  status EnrollmentStatus @default(ACTIVE)

  // relations 
  student      Student       @relation(fields: [studentId], references: [id])
  gradeLevel   GradeLevels   @relation(fields: [gradeId], references: [id])
  academicYear AcademicYears @relation(fields: [academicId], references: [id])

  @@unique([studentId, academicId])
}

