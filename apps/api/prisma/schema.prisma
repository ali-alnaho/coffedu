//             │ userName     │
//             │ password     │
//             │ role         │
//             │ createdAt    │
//             └──────────────┘
//                     │
//                     │ (future relation possible)
//                     │
//                     ▼
//             ┌──────────────┐
//             │   Student    │
//             ├──────────────┤
//             │ id (PK)      │
//             │ firstName    │
//             │ fatherName   │
//             │ ...          │
//             └──────────────┘
//                     │
//                     │ 1 → many
//                     ▼
//     ┌────────────────────────────────┐
//     │     StudentEnrollments         │
//     ├────────────────────────────────┤
